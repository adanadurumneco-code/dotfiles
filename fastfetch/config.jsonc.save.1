{
  "$schema": "https://github.com/fastfetch-cli/fastfetch/raw/dev/doc/json_schema.json",
display": {
    "separator": " : "
  },
  "modules": [
    "break",
    {
      "type": "custom",
      "format": "        ┌─────────Donanım─────────┐"
    },
    {
      "type": "host",
      "key": "💻 PC",
      "keyColor": "green"
    },
    {
      "type": "cpu",
      "key": "  ├─",
      "keyColor": "green"
    },
    {
      "type": "gpu",
      "key": "  ├─",
      "keyColor": "green"
    },
    {
      "type": "memory",
      "key": "  ├─",
      "keyColor": "green"
    },
    {
      "type": "disk",
      "key": "  └─",
      "keyColor": "green",
      "format": "{1} / {2} ({3})"
    },
    "break",
    {
      "type": "custom",
      "format": "        ┌─────────Yazılım─────────┐"
    },
    {
      "type": "os",
      "key": "🐧 Dağıtım",
      "keyColor": "yellow"
    },
    {
      "type": "de",
      "key": "  ├─ DE",
      "keyColor": "yellow",
      "format": "COSMIC"
    },
    {
      "type": "terminal",
      "key": "  ├─ Terminal",
      "keyColor": "yellow",
      "format": "Cosmic Terminal"
    },
    {
      "type": "shell",
      "key": "  └─ Shell",
      "keyColor": "yellow",
      "format": "zsh"
    },
    "break",
    {
      "type": "custom",
      "format": "        ┌──────────Linux Macerası──────────┐"
    },
    {
      "type": "custom",
      "key": "Dağıtımlar",
      "keyColor": "blue"
    },
    {
      "type": "custom",
      "key": "  ├─",
      "keyColor": "blue",
      "format": "ZorinOS (Gnome)"
    },
    {
      "type": "custom",
      "key": "  ├─",
      "keyColor": "blue",
      "format": "Pop_OS! (Cosmic)"
    },
    {
      "type": "custom",
      "key": "  └─",
      "keyColor": "blue",
      "format": "Fedora (Cosmic)"
    },
    {
      "type": "custom",
      "key": "  └─",
      "keyColor": "blue",
      "format": "CachyOS (Cosmic, I'm using Arch btw)"
    },
    "break"
  ]
}
